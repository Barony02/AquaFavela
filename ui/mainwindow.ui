  <property name="styleSheet">
   <string notr="true">/* Fundo Geral da Aplicação */
QMainWindow, QDialog {
    background-color: #2c3e50; /* Azul Marinho Escuro */
    font-family: &quot;Segoe UI&quot;, sans-serif;
}

/* Estilização dos Cards (QFrame) */
QFrame#cardStatus, QFrame#cardConsumo, QFrame#headerFrame {
    background-color: #ffffff;
    border-radius: 12px;
    border: 1px solid #dfe6e9;
}

/* Campos de Entrada (QLineEdit) */
QLineEdit {
    border: 2px solid #bdc3c7;
    border-radius: 8px;
    padding: 10px;
    background-color: #ffffff;
    font-size: 14px;
    color: #2d3436;
}

QLineEdit:focus {
    border: 2px solid #3498db; /* Azul ao focar */
}

/* Botões (QPushButton) */
QPushButton#btnAdminPanel {
    background-color: #3498db; /* Cor azul para diferenciar do login */
    color: white;
    font-weight: bold;
    font-size: 13px; /* Diminuir levemente a fonte se necessário */
    border-radius: 8px;
    padding: 5px 15px; /* Menos espaço em cima/baixo, mais nas laterais */
    
}

QPushButton:hover {
    background-color: #2ecc71;
}

QPushButton:pressed {
    background-color: #1e8449;
}

/* Barra de Status Dinâmica (lblAlerta) */
QLabel#lblAlerta {
    color: white;
    font-weight: bold;
    font-size: 16px;
    padding: 15px;
    border-radius: 8px;
    text-align: center;
}

/* Propriedades Dinâmicas da Barra de Alerta */
QLabel#lblAlerta[status=&quot;normal&quot;] {
    background-color: #27ae60;
}

QLabel#lblAlerta[status=&quot;atencao&quot;] {
    background-color: #f1c40f;
    color: #2d3436;
}

QLabel#lblAlerta[status=&quot;critico&quot;] {
    background-color: #e74c3c;
}

/* Barras de Progresso */
QProgressBar {
    border: 1px solid #bdc3c7;
    border-radius: 5px;
    background-color: #dfe6e9;
    text-align: center;
    font-weight: bold;
}

QProgressBar::chunk {
    background-color: #3498db;
    border-radius: 4px;
}

/* Labels de Erro (Login) */
QLabel#lblError {
    color: #e74c3c;
    font-weight: bold;
    background-color: rgba(231, 76, 60, 0.1);
    border: 1px solid #e74c3c;
    border-radius: 4px;
    padding: 5px;
}

QLabel#lblAlertaConsumoMax {
    background-color: transparent;
    color: transparent;
    padding: 0px; 
    border-radius: 8px;
    font-weight: bold;
    font-size: 11px;
    qproperty-alignment: 'AlignCenter';
}

/* Estado de Alerta (Visível e Vermelho) */
QLabel#lblAlertaConsumoMax[status=&quot;alerta&quot;] {
    background-color: #e74c3c;
    color: white;
    padding: 15px;
}


QLabel#lblAlertaConsumoMinuto{
    background-color: transparent;
    color: transparent;
    padding: 0px; 
    border-radius: 8px;
    font-weight: bold;
    font-size: 11px;
    qproperty-alignment: 'AlignCenter';
}

/* Estado de Alerta (Visível e Vermelho) */
QLabel#lblAlertaConsumoMinuto[status=&quot;alerta&quot;] {
    background-color: #e74c3c;
    color: white;
    padding: 15px;
}</string>
